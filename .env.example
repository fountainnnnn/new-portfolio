# Domain
SITE_DOMAIN=example.com
CADDY_EMAIL=admin@example.com

# App URLs
PUBLIC_APP_URL=https://example.com

# Local project service targets used by apps/portfolio-website/server.js
QUIZ_GENERATOR_API_URL=http://127.0.0.1:8011
MOCK_GENERATOR_API_URL=http://127.0.0.1:8012
FILE_CHAT_ASSISTANT_API_URL=http://127.0.0.1:8013
CODING_QUIZ_API_URL=http://127.0.0.1:8014
AUTO_DASHBOARD_FRONTEND_URL=http://127.0.0.1:8020
AUTO_DASHBOARD_API_URL=http://127.0.0.1:8021
SCHOOL_HDB_RESALE_URL=http://127.0.0.1:8031
SCHOOL_VEGGIE_AI_URL=http://127.0.0.1:8032

# Shared AI config
OPENAI_API_KEY=

# Portfolio app
PORT=3000
PORTFOLIO_OPENAI_MODEL=gpt-4.1-mini
CHAT_RATE_WINDOW_MS=60000
CHAT_RATE_MAX=20
PROJECT_API_RATE_WINDOW_MS=60000
PROJECT_API_RATE_MAX=8
PROJECT_API_UPLOAD_RATE_MAX=4
PROJECT_API_MAX_BODY_BYTES=26214400
PROXY_TIMEOUT_MS=300000

# Project backend limits and quality knobs
CODING_QUIZ_GENERATE_RATE_MAX=6
CODING_QUIZ_GENERATE_RATE_WINDOW_SECONDS=60
CODING_QUIZ_ANSWER_RATE_MAX=120
CODING_QUIZ_ANSWER_RATE_WINDOW_SECONDS=60
CODING_QUIZ_MODEL=gpt-4.1
CODING_QUIZ_MAX_PARALLEL_CALLS=8
CODING_QUIZ_BATCH_SIZE=5
CODING_QUIZ_OPENAI_TIMEOUT_SECONDS=20
CODING_QUIZ_RETRY_ATTEMPTS=0
FILE_CHAT_UPLOAD_RATE_MAX=4
FILE_CHAT_UPLOAD_RATE_WINDOW_SECONDS=60
FILE_CHAT_ASK_RATE_MAX=30
FILE_CHAT_ASK_RATE_WINDOW_SECONDS=60
FILE_CHAT_MODEL=gpt-5-mini
FILE_CHAT_MAX_UPLOAD_BYTES=8388608
FILE_CHAT_MAX_TEXT_CHARS=180000
FILE_CHAT_MAX_QUESTION_CHARS=1200
MOCK_GENERATOR_RATE_MAX=3
MOCK_GENERATOR_RATE_WINDOW_SECONDS=60
MOCK_GENERATOR_MODEL=gpt-4.1
MOCK_GENERATOR_MAX_UPLOAD_BYTES=20971520
MOCK_GENERATOR_MAX_PARALLEL_CALLS=3
QUIZ_GENERATOR_RATE_MAX=4
QUIZ_GENERATOR_RATE_WINDOW_SECONDS=60
QUIZ_GENERATOR_FILE_RATE_MAX=60
QUIZ_GENERATOR_FILE_RATE_WINDOW_SECONDS=60
QUIZ_GENERATOR_MODEL=gpt-4.1
QUIZ_GENERATOR_MAX_UPLOAD_BYTES=15728640
QUIZ_GENERATOR_BATCH_SIZE=5
QUIZ_GENERATOR_MAX_PARALLEL_CALLS=4

# Auto Dashboard / Decidr
AUTODASH_BASE_PATH=/auto-dashboard
AUTODASH_OPENAI_MODEL=gpt-5-mini
AUTODASH_OPENAI_PLANNER_MODEL=gpt-5-mini
AUTODASH_OPENAI_PATCH_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=low
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=/api/auto-dashboard
AUTODASH_RENDER_PLOTLY_JSON=false
AUTODASH_MAX_ROWS_FOR_RENDER=25000
AUTODASH_PARALLEL_CHARTS=true
AUTODASH_PBITOOLS_MODE=auto

# School DevOps project demos
SCHOOL_HDB_SECRET_KEY=
SCHOOL_HDB_OPENAI_MODEL=gpt-4.1-mini
SCHOOL_VEGGIE_SECRET_KEY=
