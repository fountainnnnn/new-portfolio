FLASK_ENV=development
SECRET_KEY=replace-with-a-random-secret

# Optional: override the default SQLite database path.
# SQLALCHEMY_DATABASE_URI=sqlite:///application/database.db

# Google OAuth.
GOOGLE_CLIENT_ID=replace-with-your-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-your-google-client-secret

# OpenAI chatbot.
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# OPENAI_CHAT_SYSTEM_PROMPT="You are VeggieAI Assistant. Be helpful and concise."

# Deployed CNN inference.
MODEL_INFERENCE_URL=https://example.com

# Session hardening.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_DAYS=7

# Render / reverse proxy.
TRUST_PROXY_HEADERS=false
