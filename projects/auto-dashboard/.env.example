# Backend
OPENAI_API_KEY=

# Planner model used by /dashboard/generate and /dashboard/refine.
# - gpt-5         : best quality, slowest (~25-50s per generate at medium effort)
# - gpt-5-mini    : ~3-5x faster, generally good enough for chart selection
OPENAI_MODEL=gpt-5-mini

# Reasoning effort for gpt-5* / o-series models.
# "low" is the recommended default; "medium" adds 10-30s with marginal quality gains.
# Use "minimal" for the fastest possible plan.
OPENAI_REASONING_EFFORT=low

# Optional separate model for the AI patch endpoint (Sparkles bar). Falls back to OPENAI_MODEL.
# Recommended: a smaller/cheaper model since patches are tiny ops.
OPENAI_PATCH_MODEL=gpt-5-mini

# When False (default), the backend skips Plotly figure rendering and lets the browser draw
# from the ChartSpec. Saves 3-10s on /dashboard/generate. Set to true if you depend on the
# legacy plotly_json (e.g. server-rendered image snapshots for the Power BI exporter).
AUTODASH_RENDER_PLOTLY_JSON=false

# When True (default), parallelise per-chart figure generation across a thread pool.
# Only relevant if AUTODASH_RENDER_PLOTLY_JSON=true.
AUTODASH_PARALLEL_CHARTS=true

# Hard cap on dataset rows shipped to the browser query engine.
AUTODASH_MAX_ROWS_FOR_RENDER=25000
AUTODASH_PBITOOLS_MODE=auto

FRONTEND_ORIGIN=http://localhost:3000

# Frontend
# Use these values when Decidr is served through the portfolio at /auto-dashboard.
AUTODASH_BASE_PATH=/auto-dashboard
NEXT_PUBLIC_API_BASE_URL=/api/auto-dashboard

# For standalone Decidr development, leave AUTODASH_BASE_PATH empty and use:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
