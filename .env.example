# Domain
DOMAIN=example.com

# App URLs
PUBLIC_APP_URL=https://example.com
PUBLIC_API_URL=https://api.example.com

# Local project service targets used by apps/portfolio-website/server.js
QUIZ_GENERATOR_API_URL=http://127.0.0.1:8011
MOCK_GENERATOR_API_URL=http://127.0.0.1:8012
FILE_CHAT_ASSISTANT_API_URL=http://127.0.0.1:8013
CODING_QUIZ_API_URL=http://127.0.0.1:8014

# Shared AI config
OPENAI_API_KEY=

# Portfolio app
PORT=3000
PORTFOLIO_OPENAI_MODEL=

# Auto Dashboard / Decidr
AUTODASH_OPENAI_MODEL=
OPENAI_REASONING_EFFORT=
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
AUTODASH_RENDER_PLOTLY_JSON=true
AUTODASH_MAX_ROWS_FOR_RENDER=5000
AUTODASH_PARALLEL_CHARTS=4
