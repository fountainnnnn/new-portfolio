FLASK_ENV=development
SECRET_KEY=replace-with-a-random-secret

# Optional: override the default SQLite database path.
# SQLALCHEMY_DATABASE_URI=sqlite:///application/database.db

# Optional OpenAI chatbot/insights support.
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_INSIGHTS_MODEL=gpt-4o-mini

# Optional: override context file path if you move it elsewhere.
# CHATBOT_CONTEXT_PATH=application/resources/chatbot_context.txt

# Optional: override model/data artifact paths.
# MODEL_PACKAGE_PATH=Model-Development/Models/flat_price_prediction_model.pkl
# DEMAND_MODEL_PACKAGE_PATH=Model-Development/Models/demand_prediction_model.pkl
# EXIT_VALUE_MODEL_PATH=Model-Development/Models/exit_value_prediction_model.pkl
# MODEL_DATASET_PATH=Model-Development/Data/Flat prices.csv
