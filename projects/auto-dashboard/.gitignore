# gitignore template for LangChain products, e.g., LangGraph, LangSmith
# website: https://www.langchain.com/
# website: https://www.langchain.com/langgraph

# LangGraph
.langgraph_api/

# Environment
.env
.env.local

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
backend/.venv/
backend/data/

# Node / Next.js
node_modules/
.next/
out/
dist/

# OS/editor
.DS_Store
Thumbs.db

# Local tooling - not part of the public repo
.windsurf/
.tools/

# Sample / user-supplied data files - never check in real datasets
*.csv
